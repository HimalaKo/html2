/* filepath: /_headers */
# Default cache control
/*
  Cache-Control: public, max-age=31536000, immutable

# Only preload actually critical resources
/
  Link: </assets/css/style.css>; rel=preload; as=style
  Link: </assets/js/script.js>; rel=preload; as=script

# Image optimization with longer cache
/assets/images/*
  Cache-Control: public, max-age=2592000

# JavaScript files
/assets/js/*
  Cache-Control: public, max-age=31536000

# CSS files  
/assets/css/*
  Cache-Control: public, max-age=31536000